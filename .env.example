# -----------------------------------------------------------------------------
# Rooti Server – Environment Variables (Local Development)
# Copy this file to `.env` and fill in real values. Do NOT commit .env.
# -----------------------------------------------------------------------------

# ---- App ----
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rooti
DB_USERNAME=rooti
DB_PASSWORD=rooti_local_pw

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_BASE64_VALUE_AT_LEAST_512_BITS_LONG
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14

# ---- Storage (Local FS in dev; S3 in prod) ----
STORAGE_DRIVER=local                 # local | s3
STORAGE_LOCAL_ROOT=./media
STORAGE_PUBLIC_URL=http://localhost:8080/media

# ---- Firebase (FCM Push) ----
FIREBASE_CREDENTIAL_JSON_PATH=./src/main/resources/firebase-service-account.json

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
