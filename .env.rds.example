# -----------------------------------------------------------------------------
# Rooti Server — DEV RDS opt-in 템플릿 (db-vitsdevelopmentserver 전용)
#
#   cp .env.rds.example .env.rds     # .env.rds 는 gitignore 됨
#   # 아래 값 채우기 (실제 엔드포인트/계정/비번은 절대 커밋 금지)
#   ./scripts/run_rds.sh             # 호스트 가드 후 uvicorn 실행
#
# ⚠️ 본서버(production)에는 절대 사용하지 말 것. dev RDS 전용.
#    JWT / Redis / Storage / CORS 등 비-DB 설정은 .env.dev 에서 상속됩니다.
#    v2 는 dev RDS 안의 별도 DB(rooti_v2)를 사용 — 구 Django 'postgres' DB 와 분리.
# -----------------------------------------------------------------------------

DB_HOST=<dev-rds-endpoint>.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=rooti_v2
DB_USERNAME=<db-user>
DB_PASSWORD=__set_locally_never_commit__
DB_SSL_REQUIRED=true
DB_POOL_MAX=5
DB_POOL_MIN=1
