# -----------------------------------------------------------------------------
# Rooti Server — Production (AWS RDS) environment.
#
# Copy to `.env.prod` (which is gitignored) and load with:
#   set -a; source .env.prod; set +a; ./gradlew bootRun --args='--spring.profiles.active=prod'
#
# Or set the same vars in your task definition (ECS / EKS / EB / Fargate).
# In real prod use AWS Secrets Manager or SSM Parameter Store, not files.
# -----------------------------------------------------------------------------

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
APP_BASE_URL=https://api.rooti.io

# ---- AWS RDS (PostgreSQL) ----
# Endpoint comes from the RDS console, e.g. rooti-prod.cxxx.ap-northeast-2.rds.amazonaws.com
DB_HOST=rooti-prod.cxxxxxxxxxxx.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=rooti
DB_USERNAME=rooti_app
DB_PASSWORD=__set_via_secrets_manager__

# Tell the JDBC driver to require TLS (recommended for RDS).
# When `true`, the application bumps the JDBC url with sslmode=require.
DB_SSL_REQUIRED=true

# ---- Legacy v1 schema flag ----
# When `true`, JPA entities map to the existing Django table names
# (works_*, care_*, extendauth_*, auth_user) instead of the V2 layout.
# Flyway is also kept off in this mode -- we don't manage that schema.
ROOTI_LEGACY_SCHEMA=true

# ---- Redis (ElastiCache) ----
REDIS_HOST=rooti-prod.xxxx.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT (rotate periodically) ----
# openssl rand -base64 64
JWT_SECRET=__ROTATE_ME__
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14

# ---- Storage (S3 in prod) ----
STORAGE_DRIVER=s3
STORAGE_S3_BUCKET=rooti-prod-media
STORAGE_S3_REGION=ap-northeast-2
STORAGE_PUBLIC_URL=https://cdn.rooti.io

# ---- Firebase (FCM) ----
FIREBASE_CREDENTIAL_JSON_PATH=/etc/secrets/firebase-service-account.json

# ---- CORS (운영 도메인) ----
CORS_ALLOWED_ORIGINS=https://admin.rooti.io,https://app.rooti.io
