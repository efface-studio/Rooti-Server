# -----------------------------------------------------------------------------
# Rooti Server (v2 / FastAPI) — Production 환경 템플릿
#
#   cp .env.prod.example .env.prod      # .env.prod 는 gitignore
#   # 값 채우기 — 비번/키는 절대 커밋 금지. 실제 운영은 Secrets Manager/SSM 권장.
#   set -a; source .env.prod; set +a
#   .venv/bin/gunicorn app.main:app -k uvicorn.workers.UvicornWorker \
#       --bind 0.0.0.0:8080 --workers 2
#
# 비용 최적화 사양·배포 절차: ../DEPLOYMENT.md
# 구 Django 데이터 이관: ./legacy-migration/
# -----------------------------------------------------------------------------

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
APP_BASE_URL=https://api.rooti.io

# ---- AWS RDS (PostgreSQL) ----
# 권장 사양: db.t3.small · Multi-AZ · gp3 50GB + 스토리지 오토스케일(상한 ~200GB).
# v2 는 async + 커넥션풀 + Redis 캐시 + 페이지네이션이라 small 로도 충분.
# (근거/시나리오는 DEPLOYMENT.md 의 비용 분석 참고.)
DB_HOST=<v2-prod-rds-endpoint>.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=rooti
DB_USERNAME=rooti_app            # master 계정 대신 전용 앱 유저 권장(최소권한)
DB_PASSWORD=__set_via_secrets_manager__
DB_SSL_REQUIRED=true             # RDS 는 TLS 강제 권장
DB_POOL_MAX=10
DB_POOL_MIN=1

# ---- Redis (캐시 전용) ----
# v2 는 Celery 를 쓰지 않으므로(BackgroundTasks) 브로커 불필요 — 캐시 용도만.
# 별도 ElastiCache 없이 앱 EC2 의 로컬 Redis 로도 운영 가능(비용 0).
REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT (openssl rand -base64 64, 주기적 로테이션) ----
JWT_SECRET=__set_via_secrets_manager__
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14

# ---- Storage (S3) ----
STORAGE_DRIVER=s3
STORAGE_S3_BUCKET=rooti-prod-media
STORAGE_S3_REGION=ap-northeast-2
STORAGE_PUBLIC_URL=https://cdn.rooti.io

# ---- Firebase (FCM) ----
FIREBASE_CREDENTIAL_JSON_PATH=/etc/secrets/firebase-service-account.json

# ---- Resend (transactional email) ----
RESEND_ENABLED=true
RESEND_API_KEY=__set_via_secrets_manager__
RESEND_FROM="Rooti <noreply@rooti.io>"

# ---- CORS (운영 도메인) ----
CORS_ALLOWED_ORIGINS=https://admin.rooti.io,https://app.rooti.io
