# -----------------------------------------------------------------------------
# Rooti Server — Production (AWS RDS) environment.
#
# Copy to `.env.prod` (gitignored) and load with:
#   set -a; source .env.prod; set +a; ./gradlew bootRun --args='--spring.profiles.active=prod'
#
# In real prod use AWS Secrets Manager or SSM Parameter Store, not files.
# -----------------------------------------------------------------------------

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
APP_BASE_URL=https://api.rooti.io

# ---- AWS RDS (PostgreSQL) ----
# Endpoint from the RDS console, e.g. rooti-prod.xxxx.ap-northeast-2.rds.amazonaws.com
DB_HOST=rooti-prod.xxxxxxxxxxxx.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=rooti
DB_USERNAME=rooti_app
DB_PASSWORD=__set_via_secrets_manager__

# Force TLS for the JDBC connection (RDS best practice).
DB_SSL_REQUIRED=true

# When attaching to an RDS that already received the Django→Spring data
# migration (legacy-migration/V1-django-to-spring.sql), set this to 2 so the
# next Flyway script we ship lands cleanly on top.
FLYWAY_BASELINE_VERSION=1

# ---- Redis (ElastiCache) ----
REDIS_HOST=rooti-prod.xxxx.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT (rotate periodically) ----
# openssl rand -base64 64
JWT_SECRET=__ROTATE_ME__
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14

# ---- Storage (S3 in prod) ----
STORAGE_DRIVER=s3
STORAGE_S3_BUCKET=rooti-prod-media
STORAGE_S3_REGION=ap-northeast-2
STORAGE_PUBLIC_URL=https://cdn.rooti.io

# ---- Firebase (FCM) ----
FIREBASE_CREDENTIAL_JSON_PATH=/etc/secrets/firebase-service-account.json

# ---- Resend (transactional email) ----
# Sign up at https://resend.com and create an API key. Never commit the key.
RESEND_ENABLED=true
RESEND_API_KEY=__set_via_secrets_manager__
RESEND_FROM=Rooti <noreply@rooti.io>

# ---- CORS (운영 도메인) ----
CORS_ALLOWED_ORIGINS=https://admin.rooti.io,https://app.rooti.io
