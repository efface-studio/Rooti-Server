# -----------------------------------------------------------------------------
# Rooti Server — Local dev (기본값)
#
# 복사·사용:
#   cp .env.dev.example .env.dev          # .env.dev 는 gitignore 됨
#   # JWT_SECRET 채우기 (openssl rand -base64 64)
#   docker compose up -d                  # 로컬 postgres:5433 / redis:6380
#   poetry run uvicorn app.main:app --reload  # 또는 .claude/launch.json 의 rooti-server
#
# DEV RDS(db-vitsdevelopmentserver)에 붙여 돌리려면 로컬 docker 대신:
#   cp .env.rds.example .env.rds && (비번 채우기) && ./scripts/run_rds.sh
# 실제 엔드포인트/계정/비번은 절대 커밋하지 말 것 (이 repo 는 public).
# -----------------------------------------------------------------------------

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# ---- DB: 로컬 docker postgres ----
DB_HOST=localhost
DB_PORT=5433
DB_NAME=rooti_preview
DB_USERNAME=rooti
DB_PASSWORD=rooti
DB_SSL_REQUIRED=false
DB_POOL_MAX=5
DB_POOL_MIN=1

# ---- Redis: 로컬 docker ----
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ---- JWT (openssl rand -base64 64) ----
JWT_SECRET=__set_to_a_long_random_base64_value__
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14

# ---- Storage ----
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./var/storage
STORAGE_PUBLIC_URL=http://localhost:8080/files

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
