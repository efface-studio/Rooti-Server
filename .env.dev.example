# -----------------------------------------------------------------------------
# Rooti Server — Dev environment (AWS RDS: db-vitsdevelopmentserver)
#
# 복사·사용:
#   cp .env.dev.example .env.dev          # .env.dev 는 gitignore 되어 있음
#   # 비밀번호 / JWT_SECRET / Resend 키 채우기
#   set -a; source .env.dev; set +a
#   ./gradlew bootRun --args='--spring.profiles.active=dev'
#
# RDS 인스턴스 'db-vitsdevelopmentserver' 가 db.t3.micro 라 max_connections ≈ 87 입니다.
# 동시 개발자/Preview 합쳐 conn 30 이내 유지가 목표 → 풀 max 5 default 권장.
# -----------------------------------------------------------------------------

SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# ---- AWS RDS (PostgreSQL) — db-vitsdevelopmentserver ----
DB_HOST=db-vitsdevelopmentserver.cdmci4ki2lyr.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=rootihivits
DB_PASSWORD=__paste_master_password_here__

# 운영 같은 RDS best-practice 그대로:
DB_SSL_REQUIRED=true

# 처음 실제 RDS 에 attach 할 때 한 번만:
#   - 빈 DB 면 baseline-version=1 그대로 두고 Flyway 가 V1__init_schema 부터 실행
#   - 이미 v1 Django 데이터가 있고 legacy-migration/V1-django-to-spring.sql 을 적용했다면 2
FLYWAY_BASELINE_VERSION=1

# ---- HikariCP — t3.micro 보수적 풀 ----
DB_POOL_MAX=5
DB_POOL_MIN=1
# RDS Proxy 사용 안 함 (dev 직결) → prepared-stmt 캐시 효과 위해 5 권장
PG_PREPARE_THRESHOLD=5

# ---- Redis ----
# dev 용 ElastiCache 가 없으면 로컬 docker compose 의 redis 를 그대로 가리킵니다.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
# openssl rand -base64 64 한 결과를 붙여넣기 (절대 커밋 금지)
JWT_SECRET=__set_to_a_long_random_base64_value__
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14

# ---- Storage ----
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./var/storage
STORAGE_PUBLIC_URL=http://localhost:8080/files

# ---- Firebase / FCM ----
FIREBASE_CREDENTIAL_JSON_PATH=

# ---- Resend (transactional email) ----
# 도메인 검증 끝나면 RESEND_FROM 을 noreply@hi-vits.com 으로
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM=Rooti <onboarding@resend.dev>

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
